# SplitStay Social Listener environment variables
# Copy this file to .env locally, or add these values as environment variables
# in Railway, Render, Docker, or your hosting platform.
#
# IMPORTANT: Never commit real tokens, API keys, or secrets.

# Slack
SLACK_BOT_TOKEN=
# Use the Slack channel ID, e.g. C0123456789, not the visible channel name.
SLACK_CHANNEL_ID=
# Optional: Slack user ID to tag for hot/actionable signals.
DARWIN_SLACK_ID=

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SplitStay Social Listener v1.0

# Trustpilot
TRUSTPILOT_URL=https://www.trustpilot.com/review/splitstay.travel

# Scheduler
# Monthly scan day and UTC start hour. Countries are then staggered.
SCAN_CRON_DAY=15
SCAN_CRON_HOUR=7
